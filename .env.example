PORT=4174

# Admin login for /admin.html
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_SESSION_SECRET=change-this-long-random-secret

# Keep catalog simple: current requirement allows up to 40 pages.
MAX_CATALOG_PAGES=40

# Local development stores optimized uploads in assets/uploads and catalog in data/catalog.json.
STORAGE_PROVIDER=local
CATALOG_BACKEND=local

# For Vercel/lightweight production, use Cloudinary for images and the catalog manifest.
# STORAGE_PROVIDER=cloudinary
# CATALOG_BACKEND=cloudinary
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=gunas-craft/catalog
# CLOUDINARY_MANIFEST_PUBLIC_ID=gunas-craft/catalog/catalog-manifest.json
