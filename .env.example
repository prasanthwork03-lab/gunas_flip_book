PORT=4174

# Admin login for /admin.html
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_SESSION_SECRET=change-this-long-random-secret

# Keep catalog simple: current requirement allows up to 40 pages.
MAX_CATALOG_PAGES=40

# Local development stores optimized uploads in assets/uploads and catalog in data/catalog.json.
STORAGE_PROVIDER=local
CATALOG_BACKEND=local

# Free production option for Vercel: Supabase Storage.
# Create a public Supabase Storage bucket, then set:
# STORAGE_PROVIDER=supabase
# CATALOG_BACKEND=supabase
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_BUCKET=gunas-craft-catalog
# SUPABASE_FOLDER=gunas-craft/catalog
# SUPABASE_MANIFEST_PATH=gunas-craft/catalog/catalog.json

# Alternative paid/external option: Cloudinary for images and the catalog manifest.
# STORAGE_PROVIDER=cloudinary
# CATALOG_BACKEND=cloudinary
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=gunas-craft/catalog
# CLOUDINARY_MANIFEST_PUBLIC_ID=gunas-craft/catalog/catalog-manifest.json
